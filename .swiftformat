# SwiftFormat configuration for iCodexBar
# https://github.com/nicklockwood/SwiftFormat#config-file

--swiftversion 5.9
--indent 4
--tabwidth 4
--maxwidth 120
--linebreaks lf
--semicolons never
--self remove
--voidtype Void
--closurevoid remove
--wrapenumcases always
--xcodeindentation enabled
--importgrouping alpha
--modifierorder override,acl,setteracl,dynamic,mutators,lazy,final,required

# Don't touch numeric literal grouping — defer to SwiftLint's number_separator
# rule, which requires underscores on any 4+ digit decimal (e.g. 1_000).
# SwiftFormat's default would strip those, causing CI lint to fail.
--decimalgrouping ignore
--binarygrouping ignore
--octalgrouping ignore
--hexgrouping ignore

# Match SwiftLint policy:
# - SwiftLint's `trailing_comma` rule (default-on) bans trailing commas in
#   collection literals; SwiftFormat's default `--trailing-commas always` adds
#   them. SwiftLint wins.
# - SwiftLint's `opening_brace` rule wants `{` on the same line as the
#   declaration; SwiftFormat's `wrapMultilineStatementBraces` rule pushes it
#   to the next line for wrapped signatures. Disabled.
--trailing-commas never
--disable wrapMultilineStatementBraces

--exclude vendor,Pods,build,.build,DerivedData,.swiftpm
