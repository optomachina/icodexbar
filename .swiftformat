# SwiftFormat configuration for iCodexBar
# https://github.com/nicklockwood/SwiftFormat#config-file

--swiftversion 5.9
--indent 4
--tabwidth 4
--maxwidth 120
--linebreaks lf
--semicolons never
--self remove
--voidtype Void
--closurevoid remove
--wrapenumcases always
--xcodeindentation enabled
--importgrouping alpha
--modifierorder override,acl,setteracl,dynamic,mutators,lazy,final,required

--exclude vendor,Pods,build,.build,DerivedData,.swiftpm
