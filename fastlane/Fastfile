# Fastfile for iCodexBar

default_platform(:ios)

platform :ios do
  # Project configuration
  project_name = "iCodexBar"
  repo_root = File.expand_path("..", __dir__)
  project = File.join(repo_root, "#{project_name}.xcodeproj")
  scheme = "iCodexBar"
  
  # Derived paths
  build_path = File.join(repo_root, "build")
  output_path = File.join(repo_root, "output")
  
  desc "Generate Xcode project from project.yml"
  lane :generate do
    Dir.chdir(repo_root) do
      sh("xcodegen generate")
    end
  end
  
  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      mode: :lint,
      config_file: File.join(repo_root, ".swiftlint.yml"),
      raise_if_swiftlint_error: true
    )
  end
  
  desc "Run SwiftFormat (check mode)"
  lane :format_check do
    Dir.chdir(repo_root) do
      sh("swiftformat --lint .")
    end
  end
  
  desc "Run SwiftFormat (apply changes)"
  lane :format do
    Dir.chdir(repo_root) do
      sh("swiftformat .")
    end
  end
  
  desc "Run all code quality checks"
  lane :check do
    lint
    format_check
  end
  
  desc "Build Debug configuration"
  lane :build_debug do
    sh(
      "xcodebuild",
      "build",
      "-project", project,
      "-scheme", scheme,
      "-configuration", "Debug",
      "-destination", "generic/platform=iOS Simulator",
      "-derivedDataPath", build_path,
      "CODE_SIGNING_ALLOWED=NO"
    )
  end
  
  desc "Build Release configuration"
  lane :build_release do
    sh(
      "xcodebuild",
      "build",
      "-project", project,
      "-scheme", scheme,
      "-configuration", "Release",
      "-destination", "generic/platform=iOS Simulator",
      "-derivedDataPath", build_path,
      "CODE_SIGNING_ALLOWED=NO"
    )
  end
  
  desc "Run unit tests"
  lane :test do
    sh(
      "xcodebuild",
      "test",
      "-project", project,
      "-scheme", "iCodexBarMacTests",
      "-configuration", "Debug",
      "-destination", "platform=macOS",
      "-derivedDataPath", build_path,
      "CODE_SIGNING_ALLOWED=NO"
    )
  end

  desc "Run UI tests"
  lane :ui_test do
    run_tests(
      scheme: "iCodexBar",
      configuration: "Debug",
      devices: ["iPhone 15 Pro (17.0)"],
      code_coverage: false
    )
  end
  
  desc "Build and test"
  lane :ci do
    generate
    check
    build_debug
    test
  end
  
  desc "Upload to TestFlight"
  lane :beta do
    build_release
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
  
  desc "Submit to App Store"
  lane :release do
    build_release
    upload_to_app_store(
      force: true,
      submit_for_review: true
    )
  end
end
